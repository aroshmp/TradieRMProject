# Normalise line endings for all files
* text=auto

# Backend specific files - enforce LF
*.py    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.env   text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf

# Binary files - no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary

requirements.txt text eol=lf
*.txt text eol=lf